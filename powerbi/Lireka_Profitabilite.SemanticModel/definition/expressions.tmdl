/// Normalise un transporteur à partir du numéro de suivi (tracking_id).
/// Méthode : inférence par motif, alignée sur l'analyse backend du 12/07/2026
/// (rapport_backend.txt). Sorties canoniques : UPS, La Poste, Postes Canada,
/// Chronopost, FedEx, DHL, Colis Privé, INCONNU.
/// Limite connue : les identifiants purement numériques à 10 chiffres restent
/// ambigus (DHL minoritaire vs INCONNU) et sont classés INCONNU — à valider.
expression fnNormaliserTransporteur =
		(tracking as nullable text) as text =>
		let
			// Fix F-12 : nettoyage via fnNormaliserSuivi (majuscules + trim + NBSP).
			#"Suivi nettoye" = fnNormaliserSuivi(tracking),
			longueur = Text.Length(#"Suivi nettoye"),
			// Vrai si l'identifiant ne contient que des chiffres
			estNumerique = #"Suivi nettoye" <> "" and Text.Select(#"Suivi nettoye", {"0".."9"}) = #"Suivi nettoye",
			// Application des motifs identifiés lors de l'audit backend
			#"Transporteur infere" =
				if #"Suivi nettoye" = "" then "INCONNU"
				else if Text.StartsWith(#"Suivi nettoye", "1Z") then "UPS"
				else if longueur = 13 and Text.StartsWith(#"Suivi nettoye", "6A") then "La Poste"
				else if Text.StartsWith(#"Suivi nettoye", "Q013") then "Postes Canada"
				else if longueur = 13 and (Text.StartsWith(#"Suivi nettoye", "XW") or Text.StartsWith(#"Suivi nettoye", "XA") or Text.StartsWith(#"Suivi nettoye", "XS") or Text.StartsWith(#"Suivi nettoye", "XR")) then "Chronopost"
				else if estNumerique and longueur = 18 then "FedEx"
				else if estNumerique and longueur = 12 then "DHL"
				else if Text.StartsWith(#"Suivi nettoye", "Z8") then "Colis Privé"
				else if Text.StartsWith(#"Suivi nettoye", "1C") then "Colis Privé"
				else if estNumerique and (longueur = 8 or longueur = 9) then "Colis Privé"
				else "INCONNU"
		in
			#"Transporteur infere"
	lineageTag: f6ad5b17-1ad0-46b8-9616-eba1433a28c5

/// Réduit les alias textuels de transporteurs vers un libellé canonique.
/// Couvre les alias identifiés le 12/07/2026 : My Delivengo/Delivengo/Colissimo -> La Poste,
/// UPS Standard -> UPS, DHL EXPRESS -> DHL, Postes Canada/Canada Post -> Postes Canada.
expression fnCanonTransporteur =
		(libelle as nullable text) as text =>
		let
			// Fix F-12 : normalisation via fnNormaliserSuivi (clé de matching du libellé, NBSP inclus).
			#"Libelle nettoye" = fnNormaliserSuivi(libelle),
			#"Transporteur canon" =
				if List.Contains({"DHL", "DHL EXPRESS"}, #"Libelle nettoye") then "DHL"
				else if List.Contains({"UPS", "UPS STANDARD"}, #"Libelle nettoye") then "UPS"
				else if List.Contains({"FEDEX"}, #"Libelle nettoye") then "FedEx"
				else if List.Contains({"LA POSTE", "COLISSIMO", "MY DELIVENGO", "DELIVENGO"}, #"Libelle nettoye") then "La Poste"
				else if List.Contains({"COLIS PRIVE", "COLIS PRIVÉ"}, #"Libelle nettoye") then "Colis Privé"
				else if List.Contains({"CHRONOPOST"}, #"Libelle nettoye") then "Chronopost"
				else if List.Contains({"POSTES CANADA", "CANADA POST"}, #"Libelle nettoye") then "Postes Canada"
				else "INCONNU"
		in
			#"Transporteur canon"
	lineageTag: 9274de39-62a4-4130-b72f-27746931dc50

/// Fix F-12 : normalisation robuste des clés textuelles de rapprochement.
/// Supprime les espaces insécables (NBSP U+00A0) fréquents dans les exports Excel/CSV FR,
/// applique Text.Trim puis passe en majuscules. Utilisée des DEUX côtés (colis ET factures,
/// variantes Colissimo/Chronopost) pour garantir une symétrie stricte des clés de jointure.
expression fnNormaliserSuivi =
		(x as nullable text) as text =>
		let
			v = if x = null then "" else x,
			sansNbsp = Text.Replace(v, Character.FromNumber(160), " "),
			sansEspaces = Text.Trim(sansNbsp)
		in
			Text.Upper(sansEspaces)
	lineageTag: a1b2c3d4-e5f6-4a7b-8c9d-0e1f2a3b4c5e

/// Staging (non chargé) — customer_order_item.csv nettoyé.
/// Partagé par stg_couts_bloc5_commande et fact_lignes.
expression stg_Commande_Items =
		let
			Source = Csv.Document(File.Contents(LocalRootPath & "\Données_Backend\customer_order_item.csv"), [Delimiter = ",", Encoding = 65001, QuoteStyle = QuoteStyle.Csv]),
			#"En-tetes promus" = Table.PromoteHeaders(Source, [PromoteAllScalars = true]),
			#"Types appliques" = Table.TransformColumnTypes(#"En-tetes promus", {
				{"id", Int64.Type},
				{"item_group_id", Int64.Type},
				{"order_id", Int64.Type},
				{"package_id", Int64.Type},
				{"internal_state", type text},
				{"product_cost_eur", type number},
				{"returns_and_refunds_cost_eur", type number},
				{"freight_in_cost_eur", type number},
				{"shipping_cost_to_delivery_country_eur", type number},
				{"shipping_supplies_cost_eur", type number},
				{"generic_costs_eur", type number}
			}, "en-US")
		in
			#"Types appliques"
	lineageTag: 0a8b65e4-a441-4c67-9c33-2084f7ea6296

/// Staging (non chargé) — coûts Bloc 5 agrégés par commande depuis customer_order_item.
/// Grain article → grain commande (SUM par order_id). Consommé par fact_commandes.
expression stg_couts_bloc5_commande =
		let
			Source = Table.SelectColumns(stg_Commande_Items, {"order_id", "returns_and_refunds_cost_eur", "generic_costs_eur"}),
			#"Couts agreges par commande" = Table.Group(Source, {"order_id"}, {
				{"retours_remboursements", each List.Sum(List.RemoveNulls([returns_and_refunds_cost_eur])), type number},
				{"couts_generiques", each List.Sum(List.RemoveNulls([generic_costs_eur])), type number}
			})
		in
			#"Couts agreges par commande"
	lineageTag: b5c6d7e8-f9a0-4123-b456-7890abcdef01

/// Staging (non chargé) — customer_order.csv lu et typé.
/// Consommé par fact_commandes, matching factures, dim_pays, dim_type_commande, stg_taux_moyen_mensuel.
expression stg_customer_order =
		let
			Source = Csv.Document(File.Contents(LocalRootPath & "\Données_Backend\customer_order.csv"), [Delimiter = ",", Encoding = 65001, QuoteStyle = QuoteStyle.Csv]),
			#"En-tetes promus" = Table.PromoteHeaders(Source, [PromoteAllScalars = true]),
			#"Types appliques" = Table.TransformColumnTypes(#"En-tetes promus", {
				{"id", Int64.Type},
				{"origin_order_id", type text},
				{"state", type text},
				{"source", type text},
				{"destination_country", type text},
				{"currency", type text},
				{"currency_rate", type number},
				{"order_amount_local", type number},
				{"origin_created", type text},
				{"order_amount_eur", type number},
				{"shipping_fee_eur", type number},
				{"marketplace_fees_eur", type number},
				{"product_cost_eur", type number},
				{"total_shipping_cost_to_delivery_country_eur", type number},
				{"duties_and_taxes_eur", type number},
				{"gross_profit_eur", type number},
				{"gross_margin", type number},
				{"contribution_profit_eur", type number},
				{"contribution_margin", type number}
			}, "en-US")
		in
			#"Types appliques"
	lineageTag: b3c8e1f2-4a5d-6e7f-8091-a2b3c4d5e6f7

/// Staging (non chargé) — taux de change moyen mensuel par devise.
/// Calculé à partir des lignes customer_order où currency_rate est renseigné (toutes sources).
/// Consommé par fact_commandes pour la reconstruction du CA marketplace (option B).
expression stg_taux_moyen_mensuel =
		let
			#"Date commande ajoutee" = Table.AddColumn(
				stg_customer_order,
				"date_commande",
				each try Date.FromText(Text.Start([origin_created], 10), [Format = "yyyy-MM-dd"]) otherwise null,
				type date
			),
			#"Annee mois ajoutee" = Table.AddColumn(
				#"Date commande ajoutee",
				"annee_mois",
				each if [date_commande] = null then null else Date.Year([date_commande]) * 100 + Date.Month([date_commande]),
				Int64.Type
			),
			#"Taux valides" = Table.SelectRows(
				#"Annee mois ajoutee",
				each [currency_rate] <> null and [currency] <> null and Text.Trim([currency]) <> "" and [annee_mois] <> null
			),
			#"Taux moyen par devise mois" = Table.Group(
				#"Taux valides",
				{"currency", "annee_mois"},
				{{"taux_moyen_mensuel", each List.Average([currency_rate]), type number}}
			),
			#"Colonnes renommees" = Table.RenameColumns(#"Taux moyen par devise mois", {{"currency", "devise"}})
		in
			#"Colonnes renommees"
	lineageTag: c4d5e6f7-a8b9-4012-cdef-3456789abcde

/// Staging (non chargé) — package.csv (lecture File.Contents directe).
/// Consommé par fact_transport et stg_factures_transport_resolu.
expression stg_package =
		let
			Source = Csv.Document(File.Contents(LocalRootPath & "\Données_Backend\package.csv"), [Delimiter = ",", Encoding = 65001, QuoteStyle = QuoteStyle.Csv]),
			#"En-tetes promus" = Table.PromoteHeaders(Source, [PromoteAllScalars = true]),
			#"Types appliques" = Table.TransformColumnTypes(#"En-tetes promus", {
				{"id", Int64.Type},
				{"order_id", Int64.Type},
				{"tracking_id", type text},
				{"weight", Int64.Type},
				{"shipping_cost_eur", type number},
				{"shipping_supply_cost_eur", type number},
				{"duties_taxes_eur", type number}
			}, "en-US"),
			#"Suivi normalise" = Table.AddColumn(#"Types appliques", "numero_suivi", each fnNormaliserSuivi([tracking_id]), type text)
		in
			#"Suivi normalise"
	lineageTag: a7b8c9d0-e1f2-4a3b-9c0d-1e2f3a4b5c6d

/// Staging (non chargé) — récaps Colissimo/Chronopost unifiés (sans jointure).
/// Consommé uniquement par stg_factures_transport_resolu.
expression stg_factures_brutes =
		let
			fnChronoUnifie = (src as table, facCol as text, suiviCol as text) as table =>
				let
					t = Table.TransformColumnTypes(src, {{"Date", type date}, {"Poids (kg)", type number}, {"TOTAL HT", type number}}, "fr-FR"),
					r = Table.RenameColumns(t, {{"Date", "date_facture"}, {"Poids (kg)", "poids"}, {"TOTAL HT", "cout_transport"}}),
					f = Table.AddColumn(r, "numero_facture", each try Text.From(Record.Field(_, facCol)) otherwise null, type text),
					s = Table.AddColumn(f, "numero_suivi", each fnNormaliserSuivi(Record.Field(_, suiviCol)), type text),
					tr = Table.AddColumn(s, "transporteur", each fnCanonTransporteur("Chronopost"), type text),
					sv = Table.AddColumn(tr, "service", each "Chronopost", type text),
					pdst = Table.AddColumn(sv, "pays_destination", each null, type text)
				in
					Table.SelectColumns(pdst, {"numero_facture", "date_facture", "numero_suivi", "transporteur", "service", "pays_destination", "poids", "cout_transport"}),
			ColisRacine = LocalRootPath & "\Dashboards_transporteurs\COLISSIMO Dashboard PowerBI\",
			#"Colissimo combine" = Table.Combine({
				Table.PromoteHeaders(Csv.Document(File.Contents(ColisRacine & "2025_COLISSIMO_récap.csv"), [Delimiter = ";", Encoding = 65001, QuoteStyle = QuoteStyle.Csv]), [PromoteAllScalars = true]),
				Table.PromoteHeaders(Csv.Document(File.Contents(ColisRacine & "2026_COLISSIMO_récap_au_30_juin_2026.csv"), [Delimiter = ";", Encoding = 65001, QuoteStyle = QuoteStyle.Csv]), [PromoteAllScalars = true])
			}),
			#"Colissimo types" = Table.TransformColumnTypes(#"Colissimo combine", {
				{"Date", type date},
				{"Poids kg", type number},
				{"TOTAL HT", type number}
			}, "fr-FR"),
			#"Colissimo unifie" = Table.SelectColumns(
				Table.AddColumn(
					Table.AddColumn(
						Table.AddColumn(
							Table.AddColumn(
								Table.AddColumn(
									Table.RenameColumns(#"Colissimo types", {{"Date", "date_facture"}, {"Poids kg", "poids"}, {"TOTAL HT", "cout_transport"}}),
									"numero_suivi", each fnNormaliserSuivi([#"N° de colis"]), type text),
								"numero_facture", each null, type text),
							"transporteur", each fnCanonTransporteur("Colissimo"), type text),
						"service", each "Colissimo", type text),
					"pays_destination", each try Text.BeforeDelimiter(Text.Trim([Destination]), " ") otherwise null, type text),
				{"numero_facture", "date_facture", "numero_suivi", "transporteur", "service", "pays_destination", "poids", "cout_transport"}),
			ChronoRacine = LocalRootPath & "\Dashboards_transporteurs\CHRONOPOST Dashboard PowerBI\",
			#"Chronopost 2025" = fnChronoUnifie(Table.PromoteHeaders(Csv.Document(File.Contents(ChronoRacine & "2025_CHRONOPOST_récap.csv"), [Delimiter = ";", Encoding = 65001, QuoteStyle = QuoteStyle.Csv]), [PromoteAllScalars = true]), "Facture", "N° de colis"),
			#"Chronopost 2026" = fnChronoUnifie(Table.PromoteHeaders(Csv.Document(File.Contents(ChronoRacine & "2026_CHRONOPOST_V2.csv"), [Delimiter = ";", Encoding = 65001, QuoteStyle = QuoteStyle.Csv]), [PromoteAllScalars = true]), "N° Facture", "N° de colis (N° objet)"),
			#"Chronopost unifie" = Table.Combine({#"Chronopost 2025", #"Chronopost 2026"}),
			#"Factures combinees" = Table.Combine({#"Colissimo unifie", #"Chronopost unifie"}),
			#"Lignes valides" = Table.SelectRows(#"Factures combinees", each [cout_transport] <> null),
			#"Facture en texte" = Table.TransformColumnTypes(#"Lignes valides", {{"numero_facture", type text}})
		in
			#"Facture en texte"
	lineageTag: b8c9d0e1-f2a3-4b5c-0d1e-2f3a4b5c6d7e

/// Staging (non chargé) — résolution facture -> colis par proximité de date.
/// Consommé par fact_factures_transport et fact_transport (colonne source_cout).
/// Matching ensembliste (Join + Sort + Distinct) — même règle F-11 que l'ancien row-by-row :
/// 1 candidat = accepté ; ≥2 = meilleur delta puis id_package, rejet si delta > 7j.
expression stg_factures_transport_resolu =
		let
			// Fix F-11 : fenêtre de tolérance (jours) si numéro de suivi recyclé (≥2 candidats).
			// TODO Marc: seuil à valider. Valeur par défaut conservatrice.
			FenetreToleranceJours = 7,
			#"Facture en texte" = stg_factures_brutes,
			#"Pkg suivi" = stg_package,
			#"Cmd dates" = Table.AddColumn(
				Table.SelectColumns(stg_customer_order, {"id", "origin_created"}),
				"date_commande",
				each try Date.FromText(Text.Start([origin_created], 10)) otherwise null,
				type date
			),
			#"Colis dates" = Table.ExpandTableColumn(
				Table.NestedJoin(
					Table.SelectColumns(Table.RenameColumns(#"Pkg suivi", {{"id", "id_package"}}), {"id_package", "order_id", "numero_suivi"}),
					{"order_id"},
					#"Cmd dates",
					{"id"},
					"cmd",
					JoinKind.LeftOuter
				),
				"cmd",
				{"date_commande"},
				{"date_commande"}
			),
			// Exclut les suivis vides du matching (évite produit cartésien sur "").
			#"Factures matching" = Table.SelectRows(#"Facture en texte", each [numero_suivi] <> null and [numero_suivi] <> ""),
			#"Colis dates matching" = Table.SelectRows(#"Colis dates", each [numero_suivi] <> null and [numero_suivi] <> ""),
			#"Factures index" = Table.AddIndexColumn(#"Factures matching", "inv_idx", 0, 1, Int64.Type),
			#"Candidats" = Table.Join(
				#"Factures index",
				{"numero_suivi"},
				#"Colis dates matching",
				{"numero_suivi"},
				JoinKind.Inner
			),
			#"Avec delta" = Table.AddColumn(
				#"Candidats",
				"delta",
				each if [date_commande] = null or [date_facture] = null then 1000000000.0
					else Number.Abs(Duration.TotalDays([date_commande] - [date_facture])),
				type number
			),
			#"Nb candidats" = Table.Group(
				#"Avec delta",
				{"inv_idx"},
				{{"nb_candidats_resolution", each Table.RowCount(_), Int64.Type}}
			),
			#"Tries" = Table.Sort(
				#"Avec delta",
				{{"inv_idx", Order.Ascending}, {"delta", Order.Ascending}, {"id_package", Order.Ascending}}
			),
			#"Meilleur par facture" = Table.Distinct(#"Tries", {"inv_idx"}),
			#"Meilleur + nb" = Table.ExpandTableColumn(
				Table.NestedJoin(
					#"Meilleur par facture",
					{"inv_idx"},
					#"Nb candidats",
					{"inv_idx"},
					"nb",
					JoinKind.LeftOuter
				),
				"nb",
				{"nb_candidats_resolution"},
				{"nb_candidats_resolution"}
			),
			#"Id package resolu" = Table.AddColumn(
				#"Meilleur + nb",
				"id_package_final",
				each
					if [nb_candidats_resolution] = 1 then [id_package]
					else if [delta] > FenetreToleranceJours then null
					else [id_package],
				Int64.Type
			),
			#"Order id resolu" = Table.AddColumn(
				#"Id package resolu",
				"order_id_final",
				each if [id_package_final] = null then null else [order_id],
				Int64.Type
			),
			#"Resolu colonnes" = Table.RenameColumns(
				Table.SelectColumns(#"Order id resolu", {"inv_idx", "id_package_final", "order_id_final", "nb_candidats_resolution"}),
				{{"id_package_final", "id_package"}, {"order_id_final", "order_id"}}
			),
			#"Factures resolues" = Table.ExpandTableColumn(
				Table.NestedJoin(
					#"Factures index",
					{"inv_idx"},
					#"Resolu colonnes",
					{"inv_idx"},
					"r",
					JoinKind.LeftOuter
				),
				"r",
				{"id_package", "order_id", "nb_candidats_resolution"},
				{"id_package", "order_id", "nb_candidats_resolution"}
			),
			#"Nb zero" = Table.ReplaceValue(
				#"Factures resolues",
				null,
				0,
				Replacer.ReplaceValue,
				{"nb_candidats_resolution"}
			),
			#"Colonnes finales" = Table.SelectColumns(
				Table.RemoveColumns(#"Nb zero", {"inv_idx"}),
				{
					"numero_facture", "date_facture", "numero_suivi", "transporteur", "service",
					"pays_destination", "poids", "cout_transport", "order_id", "id_package",
					"nb_candidats_resolution"
				}
			)
		in
			#"Colonnes finales"
	lineageTag: f1a2b3c4-d5e6-4f7a-8b9c-0d1e2f3a4b5c

