/// Résout un fichier CSV sur SharePoint (chemin relatif + nom) en contenu binaire.
/// Utilise SharePoint.Files pour lister récursivement et filtrer par dossier/nom.
expression fnSharePointContenuFichier =
		(dossierRelatif as text, nomFichier as text) as binary =>
		let
			UrlSite = Text.Trim(SharePointSiteURL),
			Url =
				if UrlSite = "" then
					error "Le paramètre SharePointSiteURL est vide : renseignez l'URL du site SharePoint ou de la bibliothèque contenant l'entrepôt CSV (Transformer les données > Gérer les paramètres)."
				else
					UrlSite,
			TousFichiers = SharePoint.Files(Url, [ApiVersion = 15]),
			Segments = List.Select(Text.Split(Text.Replace(dossierRelatif, "/", "\"), "\"), each _ <> ""),
			Correspondances = Table.SelectRows(
				TousFichiers,
				each
					[Name] = nomFichier
					and List.Count(List.Select(Segments, (s) => Text.Contains([Folder Path], s))) = List.Count(Segments)
			),
			Nb = Table.RowCount(Correspondances)
		in
			if Nb = 0 then
				error "Fichier SharePoint introuvable : '" & nomFichier & "' dans '" & dossierRelatif & "'. Vérifiez SharePointSiteURL et la structure des dossiers."
			else if Nb > 1 then
				error "Fichier SharePoint ambigu : " & Text.From(Nb) & " fichiers nommés '" & nomFichier & "' correspondent à '" & dossierRelatif & "'."
			else
				Correspondances{0}[Content]
	lineageTag: c8e4f1a2-9b3d-4e7f-a1c6-2d8b5e0f3a91

/// Lit un CSV backend (séparateur virgule, UTF-8) depuis SharePoint et promeut les en-têtes.
expression fnSharePointLireCsv =
		(dossierRelatif as text, nomFichier as text) as table =>
		let
			Binaire = fnSharePointContenuFichier(dossierRelatif, nomFichier),
			Source = Csv.Document(Binaire, [Delimiter = ",", Encoding = 65001, QuoteStyle = QuoteStyle.Csv])
		in
			Table.PromoteHeaders(Source, [PromoteAllScalars = true])
	lineageTag: d7f2a3b4-1c5e-4f8a-9d2b-6e0c7a1f4b82

/// Lit un CSV récap transporteur (séparateur point-virgule, UTF-8) depuis SharePoint.
expression fnSharePointLireCsvRecap =
		(dossierRelatif as text, nomFichier as text) as table =>
		let
			Binaire = fnSharePointContenuFichier(dossierRelatif, nomFichier),
			Source = Csv.Document(Binaire, [Delimiter = ";", Encoding = 65001, QuoteStyle = QuoteStyle.Csv])
		in
			Table.PromoteHeaders(Source, [PromoteAllScalars = true])
	lineageTag: e8a3b4c5-2d6f-4a9b-8e3c-7f1d8b2e5c93

