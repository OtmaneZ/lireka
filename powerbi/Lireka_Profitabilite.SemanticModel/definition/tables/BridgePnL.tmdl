/// Axe waterfall Profit bridge (page 9) - 11 lignes figees, sans dependance aux faits.
/// Ordre | Libelle | Poste | Signe (+1 revenu, -1 cout). Aucune relation vers les autres tables.
table BridgePnL
	lineageTag: b7c8d9e0-f1a2-4b3c-9d0e-1f2a3b4c5d6e

	column Ordre
		dataType: int64
		formatString: 0
		lineageTag: b7c8d9e0-f1a2-4b3c-9d0e-1f2a3b4c5d6f
		summarizeBy: none
		sourceColumn: Ordre

	column Libelle
		dataType: string
		lineageTag: b7c8d9e0-f1a2-4b3c-9d0e-1f2a3b4c5d70
		summarizeBy: none
		sourceColumn: Libelle
		sortByColumn: Ordre

	column Poste
		dataType: string
		lineageTag: b7c8d9e0-f1a2-4b3c-9d0e-1f2a3b4c5d71
		summarizeBy: none
		sourceColumn: Poste

		changedProperty = IsHidden

	column Signe
		dataType: int64
		formatString: 0
		lineageTag: b7c8d9e0-f1a2-4b3c-9d0e-1f2a3b4c5d72
		summarizeBy: none
		sourceColumn: Signe

		changedProperty = IsHidden

	partition BridgePnL = m
		mode: import
		source =
				let
					Source = #table(
						type table [Ordre = Int64.Type, Libelle = text, Poste = text, Signe = Int64.Type],
						{
							{1, "Marge brute N-1", "MB_PY", 1},
							{2, "Revenu", "CA", 1},
							{3, "Frais de port", "PORT", 1},
							{4, "Cout d'achat", "ACHAT", -1},
							{5, "Transport amont", "AMONT", -1},
							{6, "Transport aval", "OUTBOUND", -1},
							{7, "Douanes et taxes", "DOUANES", -1},
							{8, "Commissions marketplace", "COMMISSIONS", -1},
							{9, "Fournitures d'expedition", "FOURNITURES", -1},
							{10, "Retours et remboursements", "RETOURS", -1},
							{11, "Couts generiques", "GENERIQUES", -1}
						}
					),
					#"Trie par Ordre" = Table.Sort(Source, {{"Ordre", Order.Ascending}})
				in
					#"Trie par Ordre"

	annotation PBI_ResultType = Table
