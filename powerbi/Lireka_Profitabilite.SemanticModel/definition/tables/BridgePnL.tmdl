/// Axe waterfall Profit bridge (page 9) - 10 lignes figees, sans dependance aux faits.
/// Ordre | Libelle | Poste | Signe (+1 revenu, -1 cout). Aucune relation vers les autres tables.
/// Poste AMONT retire de l'axe : inbound_transportation_cost_eur = 0 depuis 2022
/// (nul sur les deux exercices du bridge YTD). Mesures [Coût Transport Amont] /
/// YoY conservees dans le modele ; alimentation du champ a poser au client.
table BridgePnL
	lineageTag: b7c8d9e0-f1a2-4b3c-9d0e-1f2a3b4c5d6e

	column Ordre
		dataType: int64
		formatString: 0
		lineageTag: b7c8d9e0-f1a2-4b3c-9d0e-1f2a3b4c5d6f
		summarizeBy: none
		sourceColumn: Ordre

	column Libelle
		dataType: string
		lineageTag: b7c8d9e0-f1a2-4b3c-9d0e-1f2a3b4c5d70
		summarizeBy: none
		sourceColumn: Libelle
		sortByColumn: Ordre

	column Poste
		dataType: string
		lineageTag: b7c8d9e0-f1a2-4b3c-9d0e-1f2a3b4c5d71
		summarizeBy: none
		sourceColumn: Poste

		changedProperty = IsHidden

	column Signe
		dataType: int64
		formatString: 0
		lineageTag: b7c8d9e0-f1a2-4b3c-9d0e-1f2a3b4c5d72
		summarizeBy: none
		sourceColumn: Signe

		changedProperty = IsHidden

	partition BridgePnL = m
		mode: import
		source =
				let
					// AMONT exclu : poste vide depuis 2022, contribution YoY nulle sur
					// 2025/2026. Mesures conservees ; reintegration possible via SWITCH.
					Source = #table(
						type table [Ordre = Int64.Type, Libelle = text, Poste = text, Signe = Int64.Type],
						{
							{1, "Prior year", "MB_PY", 1},
							{2, "Revenue", "CA", 1},
							{3, "Shipping revenue", "PORT", 1},
							{4, "Cost of goods", "ACHAT", -1},
							{5, "Outbound transport", "OUTBOUND", -1},
							{6, "Duties and taxes", "DOUANES", -1},
							{7, "Marketplace commissions", "COMMISSIONS", -1},
							{8, "Shipping supplies", "FOURNITURES", -1},
							{9, "Returns and refunds", "RETOURS", -1},
							{10, "Generic costs", "GENERIQUES", -1}
						}
					),
					#"Trie par Ordre" = Table.Sort(Source, {{"Ordre", Order.Ascending}})
				in
					#"Trie par Ordre"

	annotation PBI_ResultType = Table

