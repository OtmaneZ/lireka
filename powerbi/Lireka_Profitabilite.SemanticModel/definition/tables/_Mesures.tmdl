	/// --- KPI cards : Taux Marge Brute (Gross Margin %) — YoY en bps, pas en % ---
	measure 'Taux Marge Brute PY' = CALCULATE([Taux Marge Brute], SAMEPERIODLASTYEAR(dim_date[date]))
		formatString: 0.0%
