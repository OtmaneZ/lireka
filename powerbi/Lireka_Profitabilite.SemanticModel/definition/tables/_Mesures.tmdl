/// Table technique regroupant toutes les mesures du modèle (aucune donnée).
table _Mesures
	lineageTag: a2e58751-5502-46c6-95f8-1dc665aa31ec

	/// Nombre de commandes (grain fact_commandes).
	measure 'Nb Commandes' = COUNTROWS(fact_commandes)
		formatString: #,##0
		lineageTag: 2a5e017f-d3b9-4fc8-bc92-1f1b103b9945

	/// Nombre de colis (grain fact_transport).
	measure 'Nb Colis' = COUNTROWS(fact_transport)
		formatString: #,##0
		lineageTag: 7f531780-6ee8-4ea5-a56f-17fb98fca792

	/// Colis dont le coût provient d'une facture Colissimo/Chronopost rapprochée.
	measure 'Nb Colis (coût réel)' = CALCULATE([Nb Colis], fact_transport[source_cout] = "facture_rapprochee")
		formatString: #,##0
		lineageTag: b1c2d3e4-f5a6-4b7c-8d9e-0f1a2b3c4d5e

	/// Colis dont le coût provient du backend (shipping_cost_eur) sans facture transporteur.
	measure 'Nb Colis (coût estimé)' = CALCULATE([Nb Colis], fact_transport[source_cout] = "backend_seul")
		formatString: #,##0
		lineageTag: c2d3e4f5-a6b7-4c8d-9e0f-1a2b3c4d5e6f

	/// Colis sans facture ni coût backend renseigné (visibles en volume, exclus du coût).
	measure 'Nb Colis (coût non disponible)' = CALCULATE([Nb Colis], fact_transport[source_cout] = "aucun")
		formatString: #,##0
		lineageTag: d3e4f5a6-b7c8-4d9e-0f1a-2b3c4d5e6f7a

	/// Nombre de lignes de facture transporteur (Colissimo + Chronopost).
	measure 'Nb Colis Facturés' = COUNTROWS(fact_factures_transport)
		formatString: #,##0
		lineageTag: e8d8c253-ebbc-411c-a7c6-70f93389efb0

	/// Nombre d'articles commandés (somme des quantités).
	measure 'Nb Articles' = SUM(fact_lignes[quantity])
		formatString: #,##0
		lineageTag: 58c14c19-db5c-4284-aecc-b00079f4d9b6

	/// Chiffre d'affaires HT (order_amount_eur).
	measure 'CA Total HT' = SUM(fact_commandes[ca_ht])
		formatString: #,##0.00 €
		lineageTag: dda226fa-8e6c-4c56-acbd-56fa1c84d136

	/// CA HT reconstruit — order_amount_eur natif si présent, sinon order_amount_local / taux mensuel moyen.
	/// Variante parallèle à [CA Total HT], sur le même modèle que [Marge Brute] vs [Marge Brute (prov.)].
	/// Voir docs/notes-techniques/reconstruction-ca-marketplace.md.
	measure 'CA Total HT (reconstruit)' = SUM(fact_commandes[ca_ht_reconstruit])
		formatString: #,##0.00 €
		lineageTag: f8091234-5678-9abc-def0-123456789abc

	/// Coût d'achat total des livres (product_cost_eur).
	measure 'Coût Achat Total' = SUM(fact_commandes[cout_achat])
		formatString: #,##0.00 €
		lineageTag: 494ae678-7bb6-4cd5-a3c8-0e49d6296417

	/// Coût transport estimé par le backend (total_shipping_cost_to_delivery_country_eur).
	measure 'Coût Transport Estimé' = SUM(fact_commandes[cout_transport_estime])
		formatString: #,##0.00 €
		lineageTag: d0af07eb-f680-4e05-bc4b-b69de2131850

	/// Coût transport réel, issu des colis backend (package.shipping_cost_eur).
	measure 'Coût Transport Réel' = SUM(fact_transport[cout_transport])
		formatString: #,##0.00 €
		lineageTag: c596d85e-75bd-4785-88ba-ca8931c8a1b0

	/// Coût transport facturé par Colissimo/Chronopost (contrôle croisé).
	/// Fix F-06 : total facturé attribué au transporteur et à la date de la FACTURE elle-même
	/// (chemin direct). Comme rel_factures_transporteur / rel_factures_date sont inactives, on
	/// les active explicitement via USERELATIONSHIP et on coupe le chemin indirect (id_package)
	/// avec CROSSFILTER pour éviter toute ambiguïté.
	measure 'Coût Transport Facturé' =
			CALCULATE(
				SUM(fact_factures_transport[cout_transport]),
				USERELATIONSHIP(fact_factures_transport[transporteur], dim_transporteur[transporteur]),
				USERELATIONSHIP(fact_factures_transport[date_facture], dim_date[date]),
				CROSSFILTER(fact_factures_transport[id_package], fact_transport[id_package], None)
			)
		formatString: #,##0.00 €
		lineageTag: 0c73b641-d4e0-421c-af69-cdc593a9582e

	/// Fix F-05 : écart entre le coût transport RETENU (facturé si dispo, sinon estimé) et
	/// l'estimation backend commande. Remplace l'ancien [Écart Coût Transport] qui comparait
	/// deux estimations backend (coût colis vs coût commande), sans valeur de pilotage.
	measure 'Écart Coût Outbound vs Estimé Backend' =
			[Coût Transport Outbound (Retenu)] - [Coût Transport Estimé]
		formatString: #,##0.00 €
		lineageTag: f0b7ddaf-bbb7-42c0-9723-b40b9f621956

	/// Fix F-05 : écart coût outbound en % de l'estimé backend.
	measure 'Taux Écart Coût' = DIVIDE([Écart Coût Outbound vs Estimé Backend], [Coût Transport Estimé], 0)
		formatString: 0.0%
		lineageTag: 831022a0-57dc-4efe-b01b-6eee24553f25

	/// Coût transport réel moyen par colis.
	measure 'Coût Moyen Colis' = DIVIDE([Coût Transport Réel], [Nb Colis], 0)
		formatString: #,##0.00 €
		lineageTag: 82e52ba9-cea9-4b63-bbe3-1eac0361816e

	/// MARGE BRUTE — FORMULE PROVISOIRE. CA HT - coût d'achat - coût transport réel.
	/// Écart constaté le 12/07/2026 entre ce calcul simple et gross_profit_eur existant.
	/// À VALIDER avec Marc / finance avant de considérer comme définitive.
	measure 'Marge Brute (prov.)' = [CA Total HT] - [Coût Achat Total] - [Coût Transport Réel]
		formatString: #,##0.00 €
		lineageTag: 540144b1-b58e-46b7-8ca6-a31cc2c1da61

	/// Taux de marge brute (provisoire) = Marge Brute (prov.) / CA HT.
	measure 'Taux Marge Brute (prov.)' = DIVIDE([Marge Brute (prov.)], [CA Total HT], 0)
		formatString: 0.0%
		lineageTag: 55093196-dbb1-4824-bdbb-3de0469d326b

	/// Marge brute calculée par le backend (gross_profit_eur) — RÉFÉRENCE de contrôle.
	measure 'Marge Brute Backend (réf.)' = SUM(fact_commandes[gross_profit_eur])
		formatString: #,##0.00 €
		lineageTag: d5933b33-f893-4bba-862c-8a410050dbf1

	/// Écart entre la marge provisoire et la marge backend (aide à la validation finance).
	measure 'Écart Marge vs Backend' = [Marge Brute (prov.)] - [Marge Brute Backend (réf.)]
		formatString: #,##0.00 €
		lineageTag: 96da7a44-3aa5-400a-ae45-f6122da0451e

	/// Fix F-04 : frais de port encaissés par le client (marketplace notamment).
	/// Périmètre d'inclusion ("if relevant") non tranché — inclus par défaut dans [Marge Brute].
	measure 'Frais Port Encaissés' = SUM(fact_commandes[frais_port_encaisse])
		formatString: #,##0.00 €
		lineageTag: 5e6f7a8b-9c0d-4e1f-2a3b-4c5d6e7f8a9b

	/// Fix F-04 : coût de transport amont (inbound_transportation_cost_eur).
	measure 'Coût Transport Amont' = SUM(fact_commandes[cout_transport_amont])
		formatString: #,##0.00 €
		lineageTag: 6f7a8b9c-0d1e-4f2a-3b4c-5d6e7f8a9b0c

	/// Fix F-02/F-04 : coût transport outbound RETENU (facturé si rapproché, sinon estimé backend).
	measure 'Coût Transport Outbound (Retenu)' = SUM(fact_transport[cout_transport_retenu])
		formatString: #,##0.00 €
		lineageTag: 7a8b9c0d-1e2f-4a3b-4c5d-6e7f8a9b0c1d

	/// Fix F-04 : douanes et taxes (duties_taxes_eur) — poste "duties and taxes" de la formule Marc.
	measure 'Douanes Taxes' = SUM(fact_transport[duties_taxes_eur])
		formatString: #,##0.00 €
		lineageTag: 8b9c0d1e-2f3a-4b4c-5d6e-7f8a9b0c1d2e

	/// Fix F-04 : commissions marketplace (marketplace_fees_eur).
	measure 'Commissions Marketplace' = SUM(fact_commandes[commissions_marketplace])
		formatString: #,##0.00 €
		lineageTag: 9c0d1e2f-3a4b-4c5d-6e7f-8a9b0c1d2e3f

	/// Fix F-04 : fournitures d'expédition (shipping_supply_cost_eur).
	measure 'Fournitures Expédition' = SUM(fact_transport[shipping_supply_cost_eur])
		formatString: #,##0.00 €
		lineageTag: 0d1e2f3a-4b5c-4d6e-7f8a-9b0c1d2e3f4a

	/// MARGE BRUTE — formule confirmée par Marc Bordier (Slack, 13/07/2026 16h09).
	/// Revenue (incl. shipping revenue if relevant) - COGS - Inbound transportation costs
	/// - Outbound transportation costs - Duties and Taxes - Marketplace commission fees
	/// - Shipping supplies. Shipping revenue inclus par défaut ; "if relevant" non tranché.
	measure 'Marge Brute' =
			[CA Total HT] + [Frais Port Encaissés]
				- [Coût Achat Total]
				- [Coût Transport Amont]
				- [Coût Transport Outbound (Retenu)]
				- [Douanes Taxes]
				- [Commissions Marketplace]
				- [Fournitures Expédition]
		formatString: #,##0.00 €
		lineageTag: 1e2f3a4b-5c6d-4e7f-8a9b-0c1d2e3f4a5b

	/// Fix F-04 : taux de marge brute = Marge Brute / (CA HT + frais de port encaissés).
	measure 'Taux Marge Brute' = DIVIDE([Marge Brute], [CA Total HT] + [Frais Port Encaissés], 0)
		formatString: 0.0%
		lineageTag: 2f3a4b5c-6d7e-4f8a-9b0c-1d2e3f4a5b6c

	/// Fix F-04 : écart entre la marge conforme Marc et la marge backend (contrôle v2).
	measure 'Écart Marge vs Backend (v2)' = [Marge Brute] - [Marge Brute Backend (réf.)]
		formatString: #,##0.00 €
		lineageTag: 3a4b5c6d-7e8f-4a9b-0c1d-2e3f4a5b6c7d

	/// Nombre de commandes ayant au moins un colis avec facture transporteur rapprochée (source_cout = facture_rapprochee).
	measure 'Nb Commandes Matchées' = CALCULATE(DISTINCTCOUNT(fact_transport[order_id]), fact_transport[source_cout] = "facture_rapprochee")
		formatString: #,##0
		lineageTag: baae1892-caaa-4c58-be8e-a24bbf35a559

	/// Taux de matching facture = commandes avec coût réel (facture) / total commandes.
	measure 'Taux Matching' = DIVIDE([Nb Commandes Matchées], [Nb Commandes], 0)
		formatString: 0.0%
		lineageTag: c9fe02d1-af86-4e43-b409-66721938de41

	/// Commandes sans aucun colis rapproché à une facture transporteur.
	measure 'Nb Commandes Non Matchées' = [Nb Commandes] - [Nb Commandes Matchées]
		formatString: #,##0
		lineageTag: e49b07fe-49a0-4f51-8316-32d54fe32163

	/// Coût facturé (Colissimo/Chronopost) rapproché du colis via la relation rel_factures_colis
	/// (fact_factures_transport[id_package] -> fact_transport[id_package]), clé RÉSOLUE PAR DATE
	/// dans la partition. Remplace l'ancien TREATAS sur numero_suivi, qui rattachait la facture
	/// aux 2 colis d'un numéro de suivi recyclé (382 cas) => surcomptage.
	/// Fix F-06 : coût facturé attribué au COLIS via rel_factures_colis (clé id_package résolue
	/// par date). Relation active épinglée explicitement par USERELATIONSHIP plutôt que de
	/// compter sur une relation active implicite. Distinct de [Coût Transport Facturé] qui, lui,
	/// suit le chemin direct facture -> transporteur/date.
	measure 'Coût Facturé Rapproché' =
			CALCULATE(
				SUM(fact_factures_transport[cout_transport]),
				USERELATIONSHIP(fact_factures_transport[id_package], fact_transport[id_package])
			)
		formatString: #,##0.00 €
		lineageTag: c96ba0bc-9091-4ace-8974-29e4ffe02b25

	/// Écart entre le coût réel backend et le coût facturé transporteur (contrôle).
	/// Fix F-06 : le terme facturé passe par le chemin id_package (via [Coût Facturé Rapproché]),
	/// aligné au grain colis avec [Coût Transport Réel].
	measure 'Écart Réel vs Facturé' = [Coût Transport Réel] - [Coût Facturé Rapproché]
		formatString: #,##0.00 €
		lineageTag: e8bd1f63-4bcc-46c4-940e-133635ca4aac

	/// Nombre de colis rapprochés à une facture Colissimo/Chronopost (aligné sur source_cout = facture_rapprochee).
	measure 'Nb Colis Avec Facture' = [Nb Colis (coût réel)]
		formatString: #,##0
		lineageTag: cf7eab3c-beff-47d9-a425-381d83e6a41a

	/// Taux de rapprochement facture = colis avec facture / total colis.
	measure 'Taux Matching Factures' = DIVIDE([Nb Colis Avec Facture], [Nb Colis], 0)
		formatString: 0.0%
		lineageTag: 83eb47a3-ddff-4106-a391-6f55c64f38f7

	/// Panier moyen HT par commande.
	measure 'Panier Moyen' = DIVIDE([CA Total HT], [Nb Commandes], 0)
		formatString: #,##0.00 €
		lineageTag: 1b392be4-7f29-413b-8881-e29c3d1c99ed

	/// Poids total expédié (kg).
	measure 'Poids Total (kg)' = SUM(fact_transport[poids_kg])
		formatString: #,##0.000
		lineageTag: 594bb787-db4c-4e44-b6d2-184b63c29975

	/// Marge brute provisoire cumulée sur l'année (YTD).
	measure 'Marge YTD (prov.)' = TOTALYTD([Marge Brute (prov.)], dim_date[date])
		formatString: #,##0.00 €
		lineageTag: 28cf665e-0ecc-4980-b6cd-40f0dd3b6f10

	/// CA HT du mois précédent (time intelligence).
	measure 'CA Mois Précédent' = CALCULATE([CA Total HT], DATEADD(dim_date[date], -1, MONTH))
		formatString: #,##0.00 €
		lineageTag: 0868e48b-09c3-46ed-a947-9930a529aedf

	/// Évolution du CA vs mois précédent (%).
	measure 'Évolution CA' = DIVIDE([CA Total HT] - [CA Mois Précédent], [CA Mois Précédent], 0)
		formatString: 0.0%
		lineageTag: 97de0e8d-69dd-49d3-8d74-7a8a41d51a9e

	/// Chronopost : lignes au-delà de la 1re par numero_facture (grain multi-colis, pas un doublon qualité).
	measure 'Lignes Colis par Facture (hors 1re)' =
			VAR T =
				ADDCOLUMNS(
					FILTER(
						VALUES(fact_factures_transport[numero_facture]),
						NOT ISBLANK(fact_factures_transport[numero_facture])
							&& fact_factures_transport[numero_facture] <> ""
					),
					"Cnt", CALCULATE(COUNTROWS(fact_factures_transport))
				)
			RETURN
				SUMX(FILTER(T, [Cnt] > 1), [Cnt] - 1)
		formatString: #,##0
		lineageTag: f1a2b3c4-d5e6-4789-a012-3456789abcde

	/// Vrais doublons qualité : même numero_facture ET même numero_suivi sur plusieurs lignes.
	measure 'Vrais Doublons (Facture + Suivi)' =
			VAR T =
				ADDCOLUMNS(
					SUMMARIZE(
						fact_factures_transport,
						fact_factures_transport[numero_facture],
						fact_factures_transport[numero_suivi]
					),
					"Cnt", CALCULATE(COUNTROWS(fact_factures_transport))
				)
			RETURN
				SUMX(FILTER(T, [Cnt] > 1), [Cnt] - 1)
		formatString: #,##0
		lineageTag: e6f78901-2345-4567-f567-89abcdef0123

	/// Lignes de facture dont numero_suivi apparaît plus d'une fois (surplus hors 1re occurrence).
	measure 'Doublons Numero Suivi Factures' =
			VAR T =
				ADDCOLUMNS(
					VALUES(fact_factures_transport[numero_suivi]),
					"Cnt", CALCULATE(COUNTROWS(fact_factures_transport))
				)
			RETURN
				SUMX(FILTER(T, [Cnt] > 1), [Cnt] - 1)
		formatString: #,##0
		lineageTag: a2b3c4d5-e6f7-4890-b123-456789abcdef

	/// Commandes hors CANCELLED sans aucun colis dans fact_transport (162 attendu sur entrepôt actuel).
	measure 'Commandes Sans Colis' =
			COUNTROWS(
				FILTER(
					fact_commandes,
					fact_commandes[state] <> "CANCELLED"
						&& COUNTROWS(RELATEDTABLE(fact_transport)) = 0
				)
			)
		formatString: #,##0
		lineageTag: b3c4d5e6-f789-4012-c234-56789abcdef0

	/// Colis dont order_id ne correspond à aucune commande (intégrité référentielle).
	measure 'Colis Sans Commande' =
			COUNTROWS(
				FILTER(
					fact_transport,
					ISBLANK(RELATED(fact_commandes[id_commande]))
				)
			)
		formatString: #,##0
		lineageTag: c4d5e6f7-8901-4234-d345-6789abcdef01

	/// Lignes de facture chargées avec cout_transport nul ou absent.
	measure 'Lignes Facture Coût Transport Zero ou Null' =
			COUNTROWS(
				FILTER(
					fact_factures_transport,
					ISBLANK(fact_factures_transport[cout_transport])
						|| fact_factures_transport[cout_transport] = 0
				)
			)
		formatString: #,##0
		lineageTag: d5e6f789-0123-4345-e456-789abcdef012

	column Dummy
		lineageTag: 8b077e7c-c0c2-475a-9b63-bed5f82bf07a
		summarizeBy: none
		sourceColumn: [Dummy]

	partition _Mesures = calculated
		mode: import
		source = ROW("Dummy", BLANK())

