// Fix F-06 : cardinalités, sens de filtrage et isActive déclarés explicitement sur CHAQUE
// relation. Les deux chemins ambigus vers dim_transporteur et dim_date sont désambiguïsés
// en rendant les relations directes des factures inactives (isActive: false) ; le filtrage
// des factures passe par fact_transport (rel_factures_colis + rel_transport_transporteur).

relationship rel_transport_commandes
	fromColumn: fact_transport.order_id
	toColumn: fact_commandes.id_commande
	fromCardinality: many
	toCardinality: one
	crossFilteringBehavior: singleDirection

relationship rel_lignes_commandes
	fromColumn: fact_lignes.order_id
	toColumn: fact_commandes.id_commande
	fromCardinality: many
	toCardinality: one
	crossFilteringBehavior: singleDirection

relationship rel_commandes_pays
	fromColumn: fact_commandes.code_pays
	toColumn: dim_pays.code_pays
	fromCardinality: many
	toCardinality: one
	crossFilteringBehavior: singleDirection

relationship rel_commandes_type
	fromColumn: fact_commandes.type_commande
	toColumn: dim_type_commande.type_commande
	fromCardinality: many
	toCardinality: one
	crossFilteringBehavior: singleDirection

relationship rel_commandes_date
	fromColumn: fact_commandes.date_commande
	toColumn: dim_date.date
	fromCardinality: many
	toCardinality: one
	crossFilteringBehavior: singleDirection

relationship rel_transport_transporteur
	fromColumn: fact_transport.transporteur
	toColumn: dim_transporteur.transporteur
	fromCardinality: many
	toCardinality: one
	crossFilteringBehavior: singleDirection

// Fix F-06 : chemin direct facture -> dim_transporteur rendu INACTIF (ambigu avec
// rel_factures_colis + rel_transport_transporteur). Activable via USERELATIONSHIP si besoin.
relationship rel_factures_transporteur
	fromColumn: fact_factures_transport.transporteur
	toColumn: dim_transporteur.transporteur
	fromCardinality: many
	toCardinality: one
	crossFilteringBehavior: singleDirection
	isActive: false

// Fix F-06 : chemin direct facture -> dim_date rendu INACTIF (ambigu avec le chemin
// fact_transport -> fact_commandes -> dim_date). Activable via USERELATIONSHIP si besoin.
relationship rel_factures_date
	fromColumn: fact_factures_transport.date_facture
	toColumn: dim_date.date
	fromCardinality: many
	toCardinality: one
	crossFilteringBehavior: singleDirection
	isActive: false

/// Facture -> colis, clé résolue par proximité de date (numero_suivi recyclé).
// Fix F-06 : chemin actif de rapprochement des factures (grain colis).
relationship rel_factures_colis
	fromColumn: fact_factures_transport.id_package
	toColumn: fact_transport.id_package
	fromCardinality: many
	toCardinality: one
	crossFilteringBehavior: singleDirection
