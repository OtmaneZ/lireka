# Données sensibles — ne jamais versionner
data/raw/**
data/staging/**
data/processed/**

# Conserver la structure des dossiers
!data/raw/.gitkeep
!data/staging/.gitkeep
!data/processed/.gitkeep

# Power BI — fichiers locaux volumineux
*.pbix
*.pbit
powerbi/local/**

# Environnement
.env
.env.*
*.env

# OS & IDE
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Python
__pycache__/
*.pyc
.venv/
venv/

# Logs
logs/
*.log

# Credentials
credentials.json
secrets/
*.pem
*.key

# Power BI Datawarehouse
Power_BI_Datawarehouse/**
!Power_BI_Datawarehouse/.gitkeep

# Sorties d'audit validation (données réelles — NDA)
tools/audit-interne/*_output.json
tools/audit-interne/*_output.txt
tools/audit-interne/rapport_backend.txt